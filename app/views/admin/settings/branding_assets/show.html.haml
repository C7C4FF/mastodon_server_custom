- content_for :page_title do
  = t('admin.settings.branding_assets.title')

- content_for :heading do
  %h1= t('admin.settings.title')
  = render partial: 'admin/settings/shared/links'

= simple_form_for @admin_settings, url: admin_settings_branding_assets_path, html: { multipart: true } do |f|
  = render 'shared/error_messages', object: @admin_settings

  %p.lead= t('admin.settings.branding_assets.preamble')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :logo,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '서버 로고 공통',
                hint: '권장 픽셀: 가로형 600x200 또는 정사각형 200x200',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.logo.persisted?
        = image_tag @admin_settings.logo.file.url('display'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.logo), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :logo_dark,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '어두움 모드 로고',
                hint: '권장 픽셀: 가로형 600x200 또는 정사각형 200x200',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.logo_dark.persisted?
        = image_tag @admin_settings.logo_dark.file.url('display'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.logo_dark), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :logo_light,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '밝음 모드 로고',
                hint: '권장 픽셀: 가로형 600x200 또는 정사각형 200x200',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.logo_light.persisted?
        = image_tag @admin_settings.logo_light.file.url('display'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.logo_light), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :thumbnail,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '서버 대표 이미지',
                hint: '권장 픽셀: 1200x630',
                wrapper: :with_block_label
      - if @admin_settings.thumbnail.persisted?
        = f.input :thumbnail_description,
                  as: :text,
                  input_html: { rows: 2, maxlength: Form::AdminSettings::DESCRIPTION_LIMIT },
                  label: '이미지 설명',
                  wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.thumbnail.persisted?
        = image_tag @admin_settings.thumbnail.file.url(:'@1x'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.thumbnail), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :background,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '배경 이미지 공통',
                hint: '권장 픽셀: 2560x1440',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.background.persisted?
        = image_tag @admin_settings.background.file.url('2560'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.background), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :background_dark,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '어두움 모드 배경 이미지',
                hint: '권장 픽셀: 2560x1440',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.background_dark.persisted?
        = image_tag @admin_settings.background_dark.file.url('2560'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.background_dark), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :background_light,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '밝음 모드 배경 이미지',
                hint: '권장 픽셀: 2560x1440',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.background_light.persisted?
        = image_tag @admin_settings.background_light.file.url('2560'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.background_light), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :favicon,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '브라우저 탭 아이콘',
                hint: '권장 픽셀: 48x48',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.favicon.persisted?
        = image_tag @admin_settings.favicon.file.url('48'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.favicon), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  .fields-row
    .fields-row__column.fields-row__column-6.fields-group
      = f.input :app_icon,
                as: :file,
                input_html: { accept: f.object.class::UPLOAD_MIME_TYPES },
                label: '앱 아이콘',
                hint: '권장 픽셀: 512x512',
                wrapper: :with_block_label

    .fields-row__column.fields-row__column-6.fields-group
      - if @admin_settings.app_icon.persisted?
        = image_tag @admin_settings.app_icon.file.url('48'), class: 'fields-group__thumbnail'
        = link_to admin_site_upload_path(@admin_settings.app_icon), data: { method: :delete }, class: 'link-button link-button--destructive' do
          = material_symbol 'delete'
          = t('admin.site_uploads.delete')

  %h2 테마 조정

  .fields-group
    = f.input :branding_timeline_panel_opacity,
              as: :integer,
              input_html: { min: 0, max: 100, step: 5 },
              label: '타임라인 패널 투명도',
              hint: '0은 완전 투명, 100은 불투명입니다. 배경 이미지가 적용된 타임라인 패널에 반영됩니다.',
              wrapper: :with_block_label

  - CustomBrandingTheme::FORM_COLOR_GROUPS.each do |group|
    .branding-assets__color-section
      %h3= group[:title]

      - group[:fields].each do |field, config|
        .branding-assets__color-field
          %h4= config[:label]
          %p.hint= config[:hint]

          .fields-row
            - CustomBrandingTheme::COLOR_SCHEMES.each_value do |scheme|
              - scheme_field = CustomBrandingTheme.scheme_key(field, scheme)
              .fields-row__column.fields-row__column-6.fields-group
                .input.with_block_label.string.optional
                  %label.string.optional{ for: "form_admin_settings_#{scheme_field}" }= scheme[:title]
                  .branding-assets__color-control{ data: { branding_color_row: true } }
                    = color_field_tag nil,
                                      CustomBrandingTheme.normalize_hex(f.object.public_send(scheme_field), CustomBrandingTheme::DEFAULTS[scheme_field]),
                                      id: "#{scheme_field}_picker",
                                      data: { branding_color_picker: true }
                    = f.text_field scheme_field,
                                   id: "form_admin_settings_#{scheme_field}",
                                   pattern: '#?[0-9a-fA-F]{6}',
                                   data: { branding_color_hex: true }

  .actions
    = f.button :button, t('generic.save_changes'), type: :submit
    = f.button :button, 'Bluebirdlike UI 기본값으로 초기화', type: :submit, name: 'branding_assets_action', value: 'reset_theme', data: { confirm: '색상과 패널 투명도 설정을 Bluebirdlike UI 기본값으로 되돌릴까요?' }
